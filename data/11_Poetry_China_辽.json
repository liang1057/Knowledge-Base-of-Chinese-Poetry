{
    "萧观音": {
        "萧观音-回心院（叠锦茵）": {
            "title": "回心院（叠锦茵）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "叠锦茵，重重空自陈。",
                "只愿身当白玉体，",
                "不愿伊当薄命人。",
                "叠锦茵，待君临。"
            ],
            "content_TC": [
                "",
                "疊錦茵，重重空自陳。",
                "只願身當白玉體，",
                "不願伊當薄命人。",
                "疊錦茵，待君臨。"
            ],
            "discription": ""
        },
        "萧观音-回心院（拂象床）": {
            "title": "回心院（拂象床）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "拂象床，凭梦借高唐。",
                "敲坏半边知妾卧，",
                "恰当天处少辉光。",
                "拂象床，待君王。"
            ],
            "content_TC": [
                "",
                "拂象牀，憑夢借高唐。",
                "敲壞半邊知妾臥，",
                "恰當天處少輝光。",
                "拂象牀，待君王。"
            ],
            "discription": ""
        },
        "萧观音-回心院（换香枕）": {
            "title": "回心院（换香枕）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "换香枕，一半无云锦。",
                "为是秋来展转多，",
                "更有双双泪痕渗。",
                "换香枕，待君寝。"
            ],
            "content_TC": [
                "",
                "換香枕，一半無雲錦。",
                "爲是秋來展轉多，",
                "更有雙雙淚痕滲。",
                "換香枕，待君寢。"
            ],
            "discription": ""
        },
        "萧观音-回心院（铺翠被）": {
            "title": "回心院（铺翠被）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "铺翠被，羞杀鸳鸯对。",
                "犹忆当时叫合欢，",
                "而今独覆相思块。",
                "铺翠被，待君睡。"
            ],
            "content_TC": [
                "",
                "鋪翠被，羞殺鴛鴦對。",
                "猶憶當時叫合歡，",
                "而今獨覆相思塊。",
                "鋪翠被，待君睡。"
            ],
            "discription": ""
        },
        "萧观音-回心院（爇熏炉）": {
            "title": "回心院（爇熏炉）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "𦶟熏炉，能将孤闷苏。[1]",
                "若道妾身多秽贱，",
                "自沾御香香彻肤。",
                "𦶟熏炉，待君娱。"
            ],
            "content_TC": [
                "",
                "爇燻爐，能將孤悶蘇。[1]",
                "若道妾身多穢賤，",
                "自沾御香香徹膚。",
                "爇燻爐，待君娛。"
            ],
            "discription": ""
        },
        "萧观音-回心院（扫深殿）": {
            "title": "回心院（扫深殿）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "扫深殿，闭久金铺暗。",
                "游丝络网尘作堆，",
                "积岁青苔厚阶面。",
                "扫深殿，待君宴。"
            ],
            "content_TC": [
                "",
                "掃深殿，閉久金鋪暗。",
                "遊絲絡網塵作堆，",
                "積歲青苔厚階面。",
                "掃深殿，待君宴。"
            ],
            "discription": ""
        },
        "萧观音-回心院（剔银灯）": {
            "title": "回心院（剔银灯）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "剔银灯，须知一样明。",
                "偏是君来生彩晕，",
                "对妾故作青荧荧。",
                "剔银灯，待君行。"
            ],
            "content_TC": [
                "",
                "剔銀燈，須知一樣明。",
                "偏是君來生彩暈，",
                "對妾故作青熒熒。",
                "剔銀燈，待君行。"
            ],
            "discription": ""
        },
        "萧观音-回心院（展瑶席）": {
            "title": "回心院（展瑶席）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "展瑶席，花笑三韩碧。",
                "笑妾新铺玉一床，",
                "从来妇欢不终夕。",
                "展瑶席，待君息。"
            ],
            "content_TC": [
                "",
                "展瑤席，花笑三韓碧。",
                "笑妾新鋪玉一牀，",
                "從來婦歡不終夕。",
                "展瑤席，待君息。"
            ],
            "discription": ""
        },
        "萧观音-回心院（张鸣筝）": {
            "title": "回心院（张鸣筝）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "张鸣筝，恰恰语娇莺。",
                "一从弹作房中曲，",
                "常和窗前风雨声。",
                "张鸣筝，待君听。"
            ],
            "content_TC": [
                "",
                "張鳴箏，恰恰語嬌鶯。",
                "一從彈作房中曲，",
                "常和窗前風雨聲。",
                "張鳴箏，待君聽。"
            ],
            "discription": ""
        },
        "萧观音-回心院（装绣帐）": {
            "title": "回心院（装绣帐）",
            "author": "萧观音",
            "author_id": "I0001",
            "dynasty": "辽",
            "dynasty_id": "I",
            "content": [
                "",
                "装绣帐，金钩未敢上。",
                "解却四角夜光珠，",
                "不教照见愁模样。",
                "装绣帐，待君贶。"
            ],
            "content_TC": [
                "",
                "裝繡帳，金鉤未敢上。",
                "解卻四角夜光珠，",
                "不教照見愁模樣。",
                "裝繡帳，待君貺。"
            ],
            "discription": ""
        }
    }
}